model Admin {
  id               String  @id @default(uuid())
  userId           String  @unique
  code             String  @unique
  name             String?
  barberLogo       String?
  barberLogoUri    String?
  barberLogoFileId String? @unique

  user           User   @relation("AdminOwner", fields: [userId], references: [id])
  users          User[] @relation("AdminUsers")
  barberLogoFile File?  @relation("AdminBarberLogo", fields: [barberLogoFileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
